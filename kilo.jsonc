{
  "$schema": "https://app.kilo.ai/config.json",
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.5",
  "default_agent": "aegislane",
  "instructions": [
    ".kilo/rules/aegislane.md"
  ],
  "skills": {
    "paths": [
      ".kilo/skills",
      "~/.config/kilo/skills",
      "~/.kilo/skills",
      "~/.agents/skills",
      "~/.codex/skills",
      "~/.codex/skills/.system"
    ]
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    }
  },
  "permission": {
    "skill": {
      "*": "allow"
    },
    "bash": {
      "npx skills find*": "allow",
      "npx skills check*": "allow",
      "npx skills add*": "allow",
      "node aegislane/cli.mjs *": "allow"
    }
  }
}
